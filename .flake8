[flake8]
exclude =
    .git,
    .github,
    .idea,
    env/*,
    venv/*,
    __pycache__,
    */.ipynb_checkpoints/*

extend-ignore =
    # docstring style
    D102, D103, D104, D200, D205, D400, D401,
    # alignment whitespace (intentional style)
    E221, E231, E272,
    # blank lines
    E303,
    # import order (sys.stdout.reconfigure before imports is intentional)
    E402,
    # naming (uppercase constants inside functions are intentional)
    N803, N806,
    # TODO/FIXME markers are intentional
    T101,
    # f-strings without placeholders (harmless)
    F541,
    # continuation line alignment
    E127,
    # trailing whitespace
    W291, W293,
    # ambiguous variable names (used in statistical code)
    E741,
    # blank line counts around functions
    E302, E303, E305,
    # continuation line alignment
    E125, E131,
    # operator spacing in complex expressions
    E225,
    # multiple statements on one line (intentional in short conditionals)
    E701,
    # docstring capitalisation / missing class docstrings
    D101, D403,
    # torch.nn.functional as F and ET are standard conventions
    N812, N817,
    # block comment style, semicolons, whitespace around operators
    E201, E222, E265, E702,
    # line length (long module docstrings and data lines)
    E501,
    # set comprehension suggestion and stacklevel hint
    C401, B028

# Example of excluding errors per file
#per-file-ignores = __init__.py:F401

max-complexity = 50
max-line-length = 120
statistics=True
